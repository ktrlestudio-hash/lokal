# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Copiá este archivo como ".env" y completá los valores.
# En Netlify: configurá estas variables en Site Settings > Environment variables

# ID de tu cuenta Cloudflare (lo encontrás en el dashboard de CF, columna derecha)
CF_ACCOUNT_ID=tu_account_id_aqui

# Credenciales del API Token de R2
# Crealo en: Cloudflare Dashboard > R2 > Manage R2 API Tokens
# Permisos necesarios: Object Read & Write
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key

# Nombre del bucket de R2 que creaste
R2_BUCKET_NAME=lokal-data

# URL pública del bucket (para servir imágenes)
# Opción A: Dominio R2.dev (activarlo en el bucket: Settings > Public access)
# Ej: https://pub-abcdef123.r2.dev
# Opción B: Dominio personalizado que hayas configurado
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# ─── Firebase Auth (Google Sign-In) ──────────────────────────────────────────
# Creá un proyecto en https://console.firebase.google.com
# Anda a Project Settings > General > Your apps > Web app
# Copiá los valores del firebaseConfig:
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Para habilitar Google Sign-In:
# Firebase Console > Authentication > Sign-in method > Google > Habilitar
# En "Authorized domains" agregar tu dominio de Netlify (ej: lokal.netlify.app)

# ─── Cómo configurar R2 paso a paso ──────────────────────────────────────────
# 1. Entrá a https://dash.cloudflare.com → R2
# 2. Creá un bucket llamado "lokal-data"
# 3. En el bucket, andá a Settings → Public Access → activá el dominio R2.dev
# 4. Copiá la URL pública (ej: https://pub-xxx.r2.dev) → R2_PUBLIC_URL
# 5. Andá a R2 → Manage R2 API Tokens → Create API Token
#    - Permissions: Object Read & Write
#    - Copiá Access Key ID → R2_ACCESS_KEY_ID
#    - Copiá Secret Access Key → R2_SECRET_ACCESS_KEY
# 6. Tu Account ID está en el dashboard de CF (Overview, columna derecha)
